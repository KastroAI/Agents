# =============================================================================
# Jaded Rose Core — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# --- OpenAI ---
# API key for GPT-4o and embedding calls
OPENAI_API_KEY=sk-your-openai-api-key

# --- Pinecone ---
# API key and environment for the vector database
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1        # GCP region or Pinecone environment name
PINECONE_INDEX_NAME=jaded-rose        # Name of the Pinecone index

# --- Shopify ---
# Store URL and credentials for the Shopify Admin API
SHOPIFY_STORE_URL=https://jaded-rose.myshopify.com
SHOPIFY_ADMIN_API_KEY=shpat_your-admin-api-key
SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret

# --- GCP ---
# Google Cloud project and Pub/Sub configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_PUBSUB_TOPIC=jaded-rose-tasks    # Pub/Sub topic for agent task routing

# --- Database ---
# PostgreSQL connection string (Cloud SQL or local)
CLOUD_SQL_CONNECTION_STRING=postgresql+psycopg2://user:password@localhost:5432/jadedrose

# --- Redis ---
# Redis URL for caching and session storage
REDIS_URL=redis://localhost:6379/0
